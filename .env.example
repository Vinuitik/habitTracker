JWT_SECRET=your-base64-secret-at-least-32-chars
MCP_TOKEN=your-long-random-mcp-token
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# Trello MCP — get from https://trello.com/power-ups/admin
TRELLO_API_KEY=your-trello-api-key
TRELLO_TOKEN=your-trello-token
# Set ONE of these to target the hourly cron (name is resolved at runtime, ID is used directly)
TRELLO_CRON_BOARD_NAME=My Board Name
TRELLO_CRON_BOARD_ID=
