# REQUIRED, >=32 chars. App refuses to start without it. Generate: openssl rand -hex 32
JWT_SECRET=your-base64-secret-at-least-32-chars
MCP_TOKEN=your-long-random-mcp-token
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# ── Backup: Google Drive OAuth ──────────────────────────────────────────────
# Encrypted mongodump → Drive every BACKUP_INTERVAL_HOURS. Distinct from the
# GOOGLE_CLIENT_ID/SECRET above (that pair is the Java app's user login).
#
# Reused from ObsidianOptimizer's OAuth client — same Google Cloud client, same
# refresh token. Scope is drive.file: this app only ever sees files IT created,
# which is why the backup folder is found-or-created, never assumed to exist.
# NOTE: clicking "Disconnect" in ObsidianOptimizer's Settings revokes this token
# at Google and silently kills these backups too. Reconnect there, then re-copy
# sync.refresh_token from its app_settings table into GOOGLE_OAUTH_REFRESH_TOKEN.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-your-secret
GOOGLE_OAUTH_REFRESH_TOKEN=1//your-refresh-token

# Encrypts the dump before upload (gzip + AES-256-GCM, PBKDF2 310k iterations).
# REQUIRED — backup.py refuses to upload an unencrypted dump without it.
# LOSING THIS MEANS LOSING EVERY BACKUP: the passphrase is the only key, and it
# is not stored on Drive. Generate: openssl rand -hex 32
BACKUP_PASSPHRASE=generate-a-strong-passphrase
# Drive folder (find-or-created). The old service-account "HabitBackups" folder is
# invisible under drive.file, hence the v2 name.
BACKUP_FOLDER_NAME=HabitBackups v2
# Rolling backups retained on Drive; older ones are hard-deleted after each upload.
BACKUP_KEEP=5
BACKUP_INTERVAL_HOURS=12

# Trello MCP — get from https://trello.com/power-ups/admin
TRELLO_API_KEY=your-trello-api-key
TRELLO_TOKEN=your-trello-token
# Set ONE of these to target the hourly cron (name is resolved at runtime, ID is used directly)
TRELLO_CRON_BOARD_NAME=My Board Name
TRELLO_CRON_BOARD_ID=
